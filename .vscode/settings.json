{
  "[html]": {
    "editor.formatOnSave": false
  },
  "[javascript]": {
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.formatOnSave": true
  },
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.stickyScroll.enabled": false,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "git.openDiffOnClick": false,
  "gitlens.changes.locations": [
    "gutter",
    "line",
    "overview"
  ],
  "liveServer.settings.port": 5504,
  "search.exclude": {
    "**/*.log": true,
    "**/*.min.js": true,
    "**/node_modules": true,
    "**/.git": true,
    "**/build": true,
    "**/coverage": true,
    "**/dist": true,
    "**/*.*.*": true,
    "**/nightly": true
  },
  "workbench.colorCustomizations": {
    "activityBar.activeBorder": "#fbbf24",
    "activityBarBadge.background": "#f59e0b",
    "activityBarBadge.foreground": "#0f172a",
    "badge.background": "#f59e0b",
    "badge.foreground": "#0f172a",
    "editorCursor.foreground": "#fbbf24",
    "statusBar.debuggingBackground": "#f59e0b",
    "statusBarItem.hoverBackground": "#fbbf24",
    "titleBar.activeForeground": "#fbbf24",
    "titleBar.activeBackground": "#111827",
    "tab.activeBorderTop": "#fbbf24"
  }
}